.intro-card {
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.intro-text {
  margin-top: 12rpx;
  line-height: 1.6;
}

.form-card {
  padding: 28rpx;
  padding-bottom: 44rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-row {
  display: flex;
  gap: 18rpx;
}

.half {
  flex: 1;
}

.label {
  margin-bottom: 12rpx;
  font-weight: 700;
}

.input,
.textarea,
.picker-field {
  width: 100%;
  background: #fff5ee;
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
}

.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #9b7f74;
  font-size: 24rpx;
}

.textarea {
  display: block;
  height: 220rpx;
  margin-bottom: 12rpx;
}

.submit-btn {
  margin-top: 20rpx;
}

.submit-btn::after {
  border: none;
}
