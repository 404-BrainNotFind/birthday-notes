page {
  background: linear-gradient(180deg, #fff2e8 0%, #fff8f2 50%);
}

/* ── 成功状态 ── */
.success-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
}

.success-icon {
  font-size: 120rpx;
}

.success-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #d95f4e;
}

.success-desc {
  font-size: 30rpx;
  text-align: center;
  line-height: 1.6;
}

/* ── 填写页 ── */
.page-shell {
  min-height: 100vh;
  padding: 40rpx 24rpx 60rpx;
  box-sizing: border-box;
}

.invite-hero {
  text-align: center;
  padding: 40rpx 0 36rpx;
}

.invite-big-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.invite-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #3d302c;
  margin-bottom: 12rpx;
}

.invite-subtitle {
  font-size: 28rpx;
  line-height: 1.6;
}

/* ── 表单卡片 ── */
.form-card {
  padding: 10rpx 28rpx;
  margin-bottom: 32rpx;
}

.field-group {
  padding: 22rpx 0;
}

.field-label {
  font-size: 24rpx;
  color: #8e6f63;
  margin-bottom: 12rpx;
}

.required {
  color: #d95f4e;
}

.optional {
  color: #b8a09a;
  font-size: 22rpx;
}

.field-input {
  font-size: 30rpx;
  color: #3d302c;
  width: 100%;
}

.field-divider {
  height: 1rpx;
  background: #f3e5db;
}

.birthday-pickers {
  display: flex;
  gap: 20rpx;
  margin-top: 4rpx;
}

.picker-chip {
  background: #fff0e8;
  color: #d95f4e;
  font-size: 28rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  display: inline-block;
}

/* ── 提交按钮 ── */
.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 999rpx;
}

.submit-btn::after {
  border: none;
}
