<view class="page-shell">
  <view class="hero card">
    <view class="hero-title">别忘了重要的人</view>
    <view class="muted hero-desc">记录好友生日，提前准备祝福和心意。</view>
  </view>

  <view class="stats-grid">
    <view class="card stat-card">
      <view class="stat-num">{{stats.totalCount}}</view>
      <view class="muted">已记录人数</view>
    </view>
    <view class="card stat-card">
      <view class="stat-num">{{stats.todayCount}}</view>
      <view class="muted">今日生日</view>
    </view>
    <view class="card stat-card">
      <view class="stat-num">{{stats.within7Count}}</view>
      <view class="muted">7天内生日</view>
    </view>
    <view class="card stat-card">
      <view class="stat-num">{{stats.monthCount}}</view>
      <view class="muted">本月生日</view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">今日生日</view>
    <view class="tag">提醒</view>
  </view>

  <view wx:if="{{todayList.length === 0}}" class="card empty-card">
    <view class="muted">今天还没有生日提醒。</view>
  </view>
  <view
    wx:for="{{todayList}}"
    wx:key="id"
    class="card birthday-mini-card"
    data-id="{{item.id}}"
    bindtap="goDetail"
  >
    <view class="mini-name">{{item.name}}</view>
    <view class="muted mini-sub">{{item.relation}} · {{item.birthdayText}} · 今天生日 🎂</view>
  </view>

  <view class="section-head">
    <view class="section-title">近期生日</view>
    <button class="btn-soft small-btn" bindtap="goList">查看全部</button>
  </view>

  <view wx:if="{{upcomingList.length === 0}}" class="card empty-card">
    <view class="muted">最近还没有可展示的生日提醒。</view>
  </view>
  <view
    wx:for="{{upcomingList}}"
    wx:key="id"
    class="card birthday-mini-card"
    data-id="{{item.id}}"
    bindtap="goDetail"
  >
    <view class="mini-name">{{item.name}}</view>
    <view class="muted mini-sub">{{item.relation}} · 还有 {{item.daysUntil}} 天</view>
  </view>

  <view class="quick-row">
    <button class="btn-main quick-btn" bindtap="goAdd">添加生日</button>
    <button class="btn-soft quick-btn" bindtap="goList">查看生日簿</button>
  </view>

  <!-- 好友邀请 -->
  <view class="section-head" style="margin-top:12rpx">
    <view class="section-title">好友邀请</view>
  </view>
  <view class="invite-row">
    <view class="card invite-card" bindtap="openInviteModal">
      <view class="invite-icon">🔗</view>
      <view class="invite-label">邀请好友<br/>填写生日</view>
    </view>
    <view class="card invite-card" bindtap="goInbox">
      <view class="invite-icon">📥</view>
      <view class="invite-label">查看收件箱</view>
      <view class="inbox-badge" wx:if="{{inboxCount > 0}}">{{inboxCount}}</view>
    </view>
  </view>

  <!-- 邀请弹窗 -->
  <view class="modal-mask" wx:if="{{showInviteModal}}" bindtap="closeInviteModal">
    <view class="modal-box" catchtap="noop">
      <view class="modal-title">邀请好友填写生日</view>
      <view class="modal-body">
        <view wx:if="{{qrLoading}}" class="muted qr-tip">正在生成二维码...</view>
        <image
          wx:elif="{{inviteQRCode}}"
          src="{{inviteQRCode}}"
          class="qr-image"
          mode="aspectFit"
        />
        <view wx:else class="demo-tip">
          <view class="demo-tip-icon">📱</view>
          <view class="demo-tip-title">演示模式</view>
          <view class="muted demo-tip-desc">小程序未发布，二维码暂不可用。可用下面的方式演示好友邀请流程。</view>
        </view>
      </view>
      <button class="btn-main modal-btn" bindtap="openInvitePage">📝 打开填写页（演示好友视角）</button>
      <button class="btn-soft modal-btn" bindtap="closeInviteModal">关闭</button>
    </view>
  </view>

</view>
