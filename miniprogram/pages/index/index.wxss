.hero {
  padding: 30rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #fff2e8, #ffe1d8);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.hero-desc {
  line-height: 1.6;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  padding: 26rpx;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #d95f4e;
  margin-bottom: 8rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 8rpx 0 18rpx;
}

.small-btn {
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.small-btn::after,
.quick-btn::after {
  border: none;
}

.empty-card {
  padding: 26rpx;
  margin-bottom: 18rpx;
}

.birthday-mini-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx 26rpx;
  margin-bottom: 14rpx;
}

.mini-name {
  font-size: 30rpx;
  font-weight: 700;
}

.mini-sub {
  font-size: 24rpx;
}

.quick-row {
  display: flex;
  gap: 18rpx;
  margin-top: 14rpx;
}

.quick-btn {
  flex: 1;
}

/* ── 好友邀请 ── */
.invite-row {
  display: flex;
  gap: 18rpx;
  margin-bottom: 40rpx;
}

.invite-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  position: relative;
  gap: 10rpx;
}

.invite-icon {
  font-size: 48rpx;
}

.invite-label {
  font-size: 26rpx;
  text-align: center;
  line-height: 1.5;
  color: #5c4941;
}

.inbox-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #d95f4e;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* ── 邀请弹窗 ── */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  background: #fffdf9;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 32rpx;
  width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
  color: #3d302c;
}

.modal-body {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
  min-height: 200rpx;
  align-items: center;
}

.qr-image {
  width: 240rpx;
  height: 240rpx;
}

.qr-tip {
  font-size: 26rpx;
  text-align: center;
}

.modal-btn {
  width: 100%;
  margin-top: 14rpx;
}

.modal-btn::after {
  border: none;
}
