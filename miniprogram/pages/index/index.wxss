.hero {
  padding: 30rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #fff2e8, #ffe1d8);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.hero-desc {
  line-height: 1.6;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  padding: 26rpx;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #d95f4e;
  margin-bottom: 8rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 8rpx 0 18rpx;
}

.small-btn {
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.small-btn::after,
.quick-btn::after {
  border: none;
}

.empty-card {
  padding: 26rpx;
  margin-bottom: 18rpx;
}

.birthday-mini-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx 26rpx;
  margin-bottom: 14rpx;
}

.mini-name {
  font-size: 30rpx;
  font-weight: 700;
}

.mini-sub {
  font-size: 24rpx;
}

.quick-row {
  display: flex;
  gap: 18rpx;
  margin-top: 14rpx;
}

.quick-btn {
  flex: 1;
}
