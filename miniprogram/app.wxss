page {
  background: #fff8f2;
  color: #3d302c;
  font-size: 28rpx;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fffdf9;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(122, 72, 54, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.muted {
  color: #8e6f63;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #ffe8dd;
  color: #b45747;
}

.btn-main {
  background: #d95f4e;
  color: #ffffff;
  border-radius: 999rpx;
}

.btn-soft {
  background: #f8e8dd;
  color: #7f6055;
  border-radius: 999rpx;
}

.price-strong {
  color: #d95f4e;
  font-weight: 700;
}
